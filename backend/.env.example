JWT_REFRESH_SECRET=change_this_refresh_secret_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_EXPIRES_IN=7d

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
