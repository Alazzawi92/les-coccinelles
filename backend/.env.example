# Serveur
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=coccinelles_db
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=change_this_secret_key_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
